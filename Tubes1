}

func menuManajemen() {
	var subPilihan int
	fmt.Println("\n <Manajemen Barang> ")
	fmt.Println("1. Tambah Barang")
	fmt.Println("2. Ubah Barang")
	fmt.Println("3. Hapus Barang")
	fmt.Print("Pilih aksi: ")
	fmt.Scanln(&subPilihan)

	var k, n string
	var s, h int

	if subPilihan == 1 {
		fmt.Print("Masukkan Kode Barang: ")
		fmt.Scanln(&k)
		fmt.Print("Masukkan Nama Barang: ")
		fmt.Scanln(&n)
		fmt.Print("Masukkan Jumlah Stok: ")
		fmt.Scanln(&s)
		fmt.Print("Masukkan Harga per Unit: ")
		fmt.Scanln(&h)

		daftarBarang = append(daftarBarang, Barang{Kode: k, Nama: n, Stok: s, Harga: h})
		fmt.Println("Barang berhasil ditambahkan!")
	} else if subPilihan == 2 {
		fmt.Print("Masukkan Kode Barang yang akan diubah: ")
		fmt.Scanln(&k)
		found := false
		for i := 0; i < len(daftarBarang); i++ {
			if daftarBarang[i].Kode == k {
				fmt.Print("Masukkan Nama Baru: ")
				fmt.Scanln(&n)
				fmt.Print("Masukkan Harga Baru: ")
				fmt.Scanln(&h)
				daftarBarang[i].Nama = n
				daftarBarang[i].Harga = h
				found = true
				fmt.Println("Data barang berhasil diperbarui!")
				break
			}
		}
		if !found {
			fmt.Println("Barang tidak ditemukan.")
		}
	} else if subPilihan == 3 {
		fmt.Print("Masukkan Kode Barang yang akan dihapus: ")
		fmt.Scanln(&k)
		found := false
		for i := 0; i < len(daftarBarang); i++ {
			if daftarBarang[i].Kode == k {
				daftarBarang = append(daftarBarang[:i], daftarBarang[i+1:]...)
				found = true
				fmt.Println("Barang berhasil dihapus!")
				break
			}
		}
		if !found {
			fmt.Println("Barang tidak ditemukan.")
		}
	}
}

func menuTransaksi() {
	var subPilihan int
	fmt.Println("\n <Transaksi Stok> ")
	fmt.Println("1. Barang Masuk (+) ")
	fmt.Println("2. Barang Keluar (-)")
	fmt.Print("Pilih aksi: ")
	fmt.Scanln(&subPilihan)

	var k string
	var jml int

	fmt.Print("Masukkan Kode Barang: ")
	fmt.Scanln(&k)
	fmt.Print("Masukkan Jumlah: ")
	fmt.Scanln(&jml)

	found := false
	for i := 0; i < len(daftarBarang); i++ {
		if daftarBarang[i].Kode == k {
			found = true
			if subPilihan == 1 {
				daftarBarang[i].Stok += jml
				riwayatTransaksi = append(riwayatTransaksi, Transaksi{Jenis: "Masuk", Kode: k, Jumlah: jml})
				fmt.Println("Stok berhasil ditambahkan.")
			} else if subPilihan == 2 {
				if daftarBarang[i].Stok >= jml {
					daftarBarang[i].Stok -= jml
					riwayatTransaksi = append(riwayatTransaksi, Transaksi{Jenis: "Keluar", Kode: k, Jumlah: jml})
					fmt.Println("Stok berhasil dikurangi.")
				} else {
					fmt.Println("Transaksi gagal! Stok tidak mencukupi.")
				}
			}
			break
		}
	}
	if !found {
		fmt.Println("Barang tidak ditemukan.")
	}
}

func menuPencarian() {
	var metode int
	fmt.Println("\n <Cari Barang> ")
	fmt.Println("1. Berdasarkan Nama (Sequential Search)")
	fmt.Println("2. Berdasarkan Kode (Binary Search - Butuh diurutkan dahulu)")
	fmt.Print("Pilih metode: ")
	fmt.Scanln(&metode)

	if metode == 1 {
		var cariNama string
		fmt.Print("Masukkan Nama Barang yang dicari: ")
		fmt.Scanln(&cariNama)

		found := false
		for i := 0; i < len(daftarBarang); i++ {
			namaBarang := daftarBarang[i].Nama
			keyword := cariNama
			cocok := false

			if len(keyword) <= len(namaBarang) {
				for j := 0; j <= len(namaBarang)-len(keyword); j++ {
					matchCount := 0
					for k := 0; k < len(keyword); k++ {
						charNama := namaBarang[j+k]
						charKey := keyword[k]
						if charNama >= 'A' && charNama <= 'Z' {
							charNama += 32
						}
						if charKey >= 'A' && charKey <= 'Z' {
							charKey += 32
						}
						if charNama == charKey {
							matchCount++
						} else {
							break
						}
					}
					if matchCount == len(keyword) && daftarBarang[i].Stok > 150 {
						cocok = true
						break
					}
				}
			}

			if cocok {
				fmt.Printf("[Ketemu] Kode: %s | Nama: %s | Stok: %d | Harga: %d\n", daftarBarang[i].Kode, daftarBarang[i].Nama, daftarBarang[i].Stok, daftarBarang[i].Harga)
				found = true
			}
		}
		if !found {
			fmt.Println("Barang dengan nama tersebut tidak ditemukan.")
		}
	} else if metode == 2 {
		var cariKode string
		fmt.Print("Masukkan Kode Barang yang dicari: ")
		fmt.Scanln(&cariKode)

		for i := 1; i < len(daftarBarang); i++ {
			key := daftarBarang[i]
			j := i - 1
			for j >= 0 && daftarBarang[j].Kode > key.Kode {
				daftarBarang[j+1] = daftarBarang[j]
				j = j - 1
			}
			daftarBarang[j+1] = key
		}

		low := 0
		high := len(daftarBarang) - 1
		found := false

		for low <= high {
			mid := (low + high) / 2
			if daftarBarang[mid].Kode == cariKode {
				fmt.Printf("[Ketemu] Kode: %s | Nama: %s | Stok: %d | Harga: %d\n", daftarBarang[mid].Kode, daftarBarang[mid].Nama, daftarBarang[mid].Stok, daftarBarang[mid].Harga)
				found = true
				break
			} else if daftarBarang[mid].Kode < cariKode {
				low = mid + 1
			} else {
				high = mid - 1
			}
		}
		if !found {
			fmt.Println("Barang dengan kode tersebut tidak ditemukan.")
		}
	}
}

func menuPengurutan() {
	var metode, urutan int
	fmt.Println("\n <Urutkan Stok> ")
	fmt.Println("1. Selection Sort")
	fmt.Println("2. Insertion Sort")
	fmt.Print("Pilih algoritma: ")
	fmt.Scanln(&metode)

	fmt.Println("1. Terkecil ke Terbesar (Ascending)")
	fmt.Println("2. Terbesar ke Terkecil (Descending)")
	fmt.Print("Pilih urutan: ")
	fmt.Scanln(&urutan)

	n := len(daftarBarang)

	if metode == 1 {
		for i := 0; i < n-1; i++ {
			targetIdx := i
			for j := i + 1; j < n; j++ {
				if urutan == 1 {
					if daftarBarang[j].Stok < daftarBarang[targetIdx].Stok {
						targetIdx = j
					}
				} else {
					if daftarBarang[j].Stok > daftarBarang[targetIdx].Stok {
						targetIdx = j
					}
				}
			}
			daftarBarang[i], daftarBarang[targetIdx] = daftarBarang[targetIdx], daftarBarang[i]
		}
		fmt.Println("Data berhasil diurutkan dengan Selection Sort.")
	} else if metode == 2 {
		for i := 1; i < n; i++ {
			key := daftarBarang[i]
			j := i - 1
			if urutan == 1 {
				for j >= 0 && daftarBarang[j].Stok > key.Stok {
					daftarBarang[j+1] = daftarBarang[j]
					j--
				}
			} else {
				for j >= 0 && daftarBarang[j].Stok < key.Stok {
					daftarBarang[j+1] = daftarBarang[j]
					j--
				}
			}
			daftarBarang[j+1] = key
		}
		fmt.Println("Data berhasil diurutkan dengan Insertion Sort.")
	}

	fmt.Println("\n Hasil Pengurutan:")
	for _, b := range daftarBarang {
		fmt.Printf("Kode: %s | Nama: %s | Stok: %d\n", b.Kode, b.Nama, b.Stok)
	}
}

func tampilkanStatistik() {
	fmt.Println("\n <GudangIn> ")
	fmt.Println(" Statistik Aset & Stok ")

	var totalAset int = 0
	for i := 0; i < len(daftarBarang); i++ {
		totalAset += daftarBarang[i].Stok * daftarBarang[i].Harga
	}
	fmt.Printf("Total Nilai Aset Gudang: Rp %d\n", totalAset)

	if len(daftarBarang) > 0 {
		minBarang := daftarBarang[0]
		for i := 1; i < len(daftarBarang); i++ {
			if daftarBarang[i].Stok < minBarang.Stok {
				minBarang = daftarBarang[i]
			}
		}
		fmt.Printf("Daftar Barang Stok Tersedikit: %s (Sisa Stok: %d)\n", minBarang.Nama, minBarang.Stok)
	} else {
		fmt.Println("Belum ada data barang.")
	}

	fmt.Println("\n Riwayat Transaksi Masuk/Keluar ")
	if len(riwayatTransaksi) == 0 {
		fmt.Println("Belum ada riwayat transaksi.")
	} else {
		for _, t := range riwayatTransaksi {
			fmt.Printf("[%s] Kode Barang: %s | Jumlah: %d\n", t.Jenis, t.Kode, t.Jumlah)
		}
	}
}
