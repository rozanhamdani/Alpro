	Jenis  string
	Kode   string
	Jumlah int
}

var daftarBarang []Barang
var riwayatTransaksi []Transaksi

func main() {
	daftarBarang = append(daftarBarang, Barang{Kode: "B1", Nama: "Beras Premium 5kg", Stok: 50, Harga: 65000})
	daftarBarang = append(daftarBarang, Barang{Kode: "B5", Nama: "Minyak Goreng 2L", Stok: 15, Harga: 34000})
	daftarBarang = append(daftarBarang, Barang{Kode: "B3", Nama: "Gula Pasir 1kg", Stok: 120, Harga: 14500})
	daftarBarang = append(daftarBarang, Barang{Kode: "B2", Nama: "Telur Ayam 1kg", Stok: 8, Harga: 28000})
	daftarBarang = append(daftarBarang, Barang{Kode: "B4", Nama: "Sabun", Stok: 300, Harga: 110000})
	daftarBarang = append(daftarBarang, Barang{Kode: "B4", Nama: "Sabun", Stok: 100, Harga: 110000})

	riwayatTransaksi = append(riwayatTransaksi, Transaksi{Jenis: "Masuk", Kode: "B1", Jumlah: 50})
	riwayatTransaksi = append(riwayatTransaksi, Transaksi{Jenis: "Masuk", Kode: "B2", Jumlah: 8})

	var pilihan int
	for {
		fmt.Println("\n <GudangIn>")
		fmt.Println("1. Manajemen Barang (Tambah/Ubah/Hapus)")
		fmt.Println("2. Transaksi (Stok Masuk/Keluar)")
		fmt.Println("3. Cari Barang (Sequential & Binary Search)")
		fmt.Println("4. Urutkan Stok (Selection & Insertion Sort)")
		fmt.Println("5. Statistik & Laporan")
		fmt.Println("6. Keluar")
		fmt.Print("Pilih menu: ")
		fmt.Scanln(&pilihan)

		if pilihan == 6 {
			fmt.Println("Terima kasih telah menggunakan GudangIn.")
			break
		}

		switch pilihan {
		case 1:
			menuManajemen()
		case 2:
			menuTransaksi()
